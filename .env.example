# Embedding model (HuggingFace model name)
EMBEDDING_MODEL=aisingapore/SEA-LION-Embedding-300M

# LLM (OpenAI-compatible endpoint)
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
OPENAI_API_KEY=ollama
LLM_MODEL=aisingapore/Qwen-SEA-LION-v4-32B-IT
LLM_TEMPERATURE=0.3 # Optional

# HuggingFace cache (host path, default is ~/.cache/huggingface)
HF_CACHE_PATH=~/.cache/huggingface

# ChromaDB connection (use service name inside docker-compose)
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=sea_lion_docs

# App settings
TOP_K=5
CHUNK_SIZE=500
CHUNK_OVERLAP=100
